{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pkg Manager",
  "version": "0.1.0",
  "identifier": "com.pkg-manager.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "npm run dev -- --port 5180",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pkg Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
